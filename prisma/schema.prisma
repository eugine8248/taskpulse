// taskpulse — SQLite schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String?
  // Bumped on logout-everywhere / password change to invalidate every JWT
  // previously issued for this user. Embedded as `tv` claim in every token.
  tokenVersion Int      @default(0)
  createdAt    DateTime @default(now())

  // GitHub PAT integration (v2.5). PAT is AES-256-GCM encrypted server-side
  // with PAT_ENCRYPTION_KEY env var. Login + scopes are cached for display.
  githubPatEncrypted String?
  githubLogin        String?
  githubScopes       String?

  boards    Board[]
  labels    Label[]
  auditLogs AuditLog[]
}

model Board {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String   @default("Project")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // v2.5/v2.6 GitHub binding fields removed in cleanup. Per-card githubKind
  // metadata + the PAT-storage on User + the paste-URL flow remain; the
  // board-level binding + auto-sync + webhook layer was overkill for solo work.

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  columns Column[]

  @@index([userId])
}

model Column {
  id        Int     @id @default(autoincrement())
  boardId   Int
  name      String
  // Float so reorders never need integer rebalancing
  order     Float
  // null = no WIP limit; integer >= 1 = soft warn when count exceeds
  wipLimit  Int?

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([boardId])
}

model Card {
  id          Int       @id @default(autoincrement())
  columnId    Int
  title       String
  description String    @default("")
  priority    String    @default("medium") // 'low' | 'medium' | 'high' | 'urgent'
  dueDate     DateTime?
  pinnedAt    DateTime?
  order       Float
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // GitHub-derived card fields (v2.5). When githubKind is set, the card
  // mirrors a PR / issue / commit and is unique per-column-per-URL so
  // re-imports upsert rather than duplicate.
  githubKind          String?
  githubUrl           String?
  githubNumber        Int?
  githubSha           String?
  githubState         String?
  githubMetadata      String?
  githubLastFetchedAt DateTime?

  column      Column          @relation(fields: [columnId], references: [id], onDelete: Cascade)
  cardLabels  CardLabel[]
  comments    CardComment[]
  events      CardEvent[]
  timeEntries TimeEntry[]
  attachments CardAttachment[]

  @@index([columnId])
  @@index([pinnedAt])
  @@index([githubKind, githubState])
  @@unique([columnId, githubUrl], name: "uniq_card_per_col_per_url")
}

model CardComment {
  id           Int      @id @default(autoincrement())
  cardId       Int
  body         String
  authorUserId Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([authorUserId])
}

model CardEvent {
  id           Int      @id @default(autoincrement())
  cardId       Int
  // 'created'|'moved'|'priority_changed'|'pinned'|'unpinned'|'completed'|'commented'|'time_logged'|'attached'|'tagged'
  kind         String
  meta         String?  // JSON-encoded extras
  actorUserId  Int
  createdAt    DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([createdAt])
}

model TimeEntry {
  id           Int       @id @default(autoincrement())
  cardId       Int
  startedAt    DateTime
  endedAt      DateTime?
  durationMs   Int?
  note         String?
  authorUserId Int
  createdAt    DateTime  @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([authorUserId, endedAt])
}

model CardAttachment {
  id           Int      @id @default(autoincrement())
  cardId       Int
  fileUrl      String
  fileKey      String
  mimeType     String
  byteSize     Int
  originalName String
  authorUserId Int
  uploadedAt   DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

model SavedView {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String
  filter    String   // JSON
  sort      String   // JSON
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

model CardTemplate {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String
  cards     String   // JSON: array of {title, description?, priority?, tags?[]}
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

model Label {
  id     Int    @id @default(autoincrement())
  userId Int
  name   String

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardLabels CardLabel[]

  @@unique([userId, name])
  @@index([userId])
}

model CardLabel {
  cardId  Int
  labelId Int

  card  Card  @relation(fields: [cardId],  references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
  @@index([labelId])
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  ip        String
  userAgent String
  action    String   // 'login_success' | 'login_failure' | 'register' | 'password_change' | 'logout_everywhere'
  meta      String?  // JSON-encoded extras
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
