# taskpulse — environment variables (all optional for localhost dev)
# Copy to `.env` if you need to override defaults.

# --- Server ---
# Port the Express server listens on (also serves the built client in prod)
PORT=3000

# SQLite database location — relative paths resolved from the prisma schema dir
DATABASE_URL=file:../data/taskpulse.db

# JWT signing secret. CHANGE THIS in any deployment beyond localhost.
JWT_SECRET=change-me-locally

# Bypass auth entirely (single-user local mode).
# IMPORTANT: ignored when NODE_ENV=production — production always requires auth.
NO_AUTH=false

# --- Reports ---
# Override where the server reads report markdown from.
# Defaults to <repo>/data/reports/ (Option B repo-local seed data).
# REPORTS_DIR=/path/to/your/reports
