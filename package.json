{
  "name": "taskpulse",
  "version": "2.5.0",
  "private": true,
  "description": "Kanban + CLI + PWA task management with pin/focus, time tracking, FTS5 search",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install:all": "npm install --workspaces --include-workspace-root && npm run prisma:generate",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "prisma:dev": "prisma migrate dev --schema=./prisma/schema.prisma",
    "dev:client": "npm --workspace client run dev",
    "dev:server": "npm --workspace server run dev",
    "dev": "npm-run-all --parallel dev:server dev:client",
    "build:client": "npm --workspace client run build",
    "build:server": "npm --workspace server run build",
    "build": "npm run prisma:generate && npm run build:client && npm run build:server",
    "start": "npm --workspace server run start"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "prisma": "^5.22.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  }
}
